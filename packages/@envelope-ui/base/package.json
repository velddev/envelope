{
  "name": "@envelope-ui/base",
  "version": "1.0.0",
  "description": "Envelope base design package",
  "repository": {
    "type": "git",
    "url": "https://github.com/velddev/envelope.git"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "files": [
    "/dist"
  ],
  "scripts": {
    "build:cjs": "swc src -d dist/cjs --config-file .swcrc -C module.type=commonjs --strip-leading-paths",
    "build:esm": "swc src -d dist/esm --config-file .swcrc -C module.type=es6 --strip-leading-paths",
    "build:dts": "tsc --emitDeclarationOnly --declaration --outDir dist/types",
    "build": "npm run build:cjs && npm run build:esm && npm run build:dts",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "clean": "rimraf dist"
  },
  "license": "MIT",
  "author": "Mike Veldsink",
  "peerDependencies": {
    "framer-motion": "7.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@storybook/addon-actions": "^6.4.8",
    "@storybook/addon-essentials": "^6.4.8",
    "@storybook/addon-links": "^6.4.8",
    "@storybook/react": "^6.5.8",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.10.0",
    "@tsconfig/recommended": "^1.0.8",
    "@typescript-eslint/eslint-plugin": "^4.32.0",
    "@typescript-eslint/parser": "^4.32.0",
    "eslint": "^7.2.0",
    "eslint-config-airbnb": "18.2.1",
    "eslint-config-airbnb-typescript": "^14.0.0",
    "eslint-config-next": "^11.1.2",
    "eslint-config-prettier": "^8.3.0",
    "eslint-config-react-app": "^6.0.0",
    "eslint-import-resolver-babel-module": "^5.3.1",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-flowtype": "^6.1.0",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-jest": "^24.4.3",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-react-hooks": "^4.2.0",
    "resolve-tspaths": "^0.8.23",
    "rollup": "^3.26.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.35.0",
    "tsconfig-paths-webpack-plugin": "^3.5.2",
    "tsup": "^8.3.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-portal": "^1.1.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react-aria-components": "^1.3.3",
    "sonner": "^1.5.0",
    "tailwind-merge": "^3.5.0",
    "use-breakpoint": "^3.1.1"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  }
}
